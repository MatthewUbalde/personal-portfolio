---
/**
 * Explores my experience as a game developer.
 * Highlights my intrigue in game development and my thought process in these games.
 */
import { getCollection } from "astro:content";

import Layout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import BadgeDisplay from "../../components/BadgeDisplay.astro";

import ContainerProject from "../../components/ContainerProject.astro";
import ProjectShowcase from "../../components/ProjectShowcase.astro";
import LayoutSection from "../../components/LayoutSection.astro";
import DropdownContainer from "../../components/DropdownContainer.astro";

const projects = (await getCollection("gamesArticles")).sort(
  (a, b) => b.data.published?.valueOf() - a.data.published?.valueOf(),
);

const experiences = await getCollection("experiences");
const expGame = experiences[0].filters((e) => e.type.includes("game"));
---

<Layout
  title="Game"
  description="Have experience in Godot and Unity to create well designed games"
>
  <LayoutSection col class="items-center">
    <Container noMargin textContent class="md:w-3/4">
      <h1>Experience Summary</h1>
      <p>
        Was taught on how to use the Unity Engine, but developed games as a
        side-hobby with Godot. This is purely as an interest, but willing to try
        to break into this industry when given the opportunity.
      </p>
    </Container>

    {
      expGame && (
        <DropdownContainer class="w-full h-fit">
          <Fragment slot="header">
            <h1>Game Experience</h1>
          </Fragment>
          <BadgeDisplay src={expGame.data} title="Game Engines" />
        </DropdownContainer>
      )
    }
  </LayoutSection>
  <div>
    <Container textContent class="sm:w-1/2 sm:mx-auto">
      <h1>Games for Fun</h1>
      <p>
        These are purely made out of fun as I found the game development
        interesting since I was really young. I like making games that are
        simple, but tried to make it deep and rewarding at the same time.
      </p>
    </Container>
    {
      projects && (
        <ContainerProject>
          {projects.map((p) => (
            <ProjectShowcase
              {...p.data}
              href={`/personal-portfolio-astro/projects/games/${p.id}`}
            />
          ))}
        </ContainerProject>
      )
    }
  </div>
</Layout>
