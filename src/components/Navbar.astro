---
import { Image } from "astro:assets";

import portraitImg from "../assets/portfolio-portrait.png";

const asPath = Astro.url.pathname;
---

<header
  class="z-50 pointer-events-auto group sticky inset-x-0 top-0 p-2 from-gray-950 to-transparent bg-linear-to-b"
>
  <div class="flex gap-2 mx-auto lg:w-2/3">
    <Image
      src={portraitImg}
      alt="Portrait of Matthew Ubalde"
      class="hidden sm:block bg-slate-900 size-16 rounded-xl"
    />
    <nav class="flex flex-col justify-center w-full h-full">
      <h1><a href="/">Matthew Ubalde</a></h1>
      <div
        class="flex flex-wrap gap-2 text-3xl md:text-2xl text-sky-300 *:bg-slate-900 *:shadow-md *:rounded-md *:px-2"
      >
        <a href="/projects" class="font-bold">{"> "}Projects</a>
        <div class="group/inner flex flex-wrap gap-2">
          <a href="/career" class="font-bold">{"> "}Career</a>
          <a
            href="/career/software"
            class:list={[asPath.includes("software") && "opacity-50"]}
            >Software</a
          >
          <a
            href="/career/mobile"
            class:list={[asPath.includes("mobile") && "opacity-50"]}>Mobile</a
          >
          <a
            href="/career/web"
            class:list={[asPath.includes("web") && "opacity-50"]}>Web</a
          >
          <a
            href="/career/game"
            class:list={[asPath.includes("game") && "opacity-50"]}>Game</a
          >
          <a
            href="/career/art"
            class:list={[asPath.includes("art") && "opacity-50"]}>Art</a
          >
        </div>
      </div>
    </nav>
  </div>
</header>
