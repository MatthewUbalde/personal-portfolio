---
import type { HTMLAttributes } from "astro/types";

import { SITE_NAVIGATION } from "../const";
import Section from "./Section.astro";

type Props = HTMLAttributes<"footer">;

const { class: className, ...props } = Astro.props;
---

<footer
  class:list={["flex justify-end items-center gap-2 m-4", className]}
  {...props}
>
  <div class="flex flex-row justify-start items-stretch gap-2 flex-wrap">
    {
      SITE_NAVIGATION.map((nav) => (
        <Section
          noMargin
          noPadding
          class="flex flex-col justify-center items-start flex-wrap p-2"
        >
          <a href={nav.href} class="sm:text-sm">
            {nav.label}
          </a>
          {nav.children && (
            <div class="flex flex-row gap-2 flex-wrap text-sky-100">
              {nav.children.map((cnav) => (
                <a href={`${nav.href}${cnav.href}`} class="text-sm sm:text-xs">
                  {cnav.label}
                </a>
              ))}
            </div>
          )}
        </Section>
      ))
    }
  </div>
  <div class="text-xs sm:text-sm text-center [writing-mode:vertical-rl]">
    Site Map
  </div>
</footer>
