---
/**
 * The base of the entire website.
 * It holds the metadata in the head, Navbars, and holds the main content.
 */
import { Image } from "astro:assets";

import Footer from "../components/Footer.astro";
import BaseHead from "../components/BaseHead.astro";

import portraitImg from "../assets/portfolio-portrait.png";

import NavbarDesktop from "../components/Navbar/NavbarDesktop.astro";
import NavbarMobile from "../components/Navbar/NavbarMobile.astro";

import gridBg from "../assets/grid-bg.svg";

const pathname = Astro.url.pathname;
const currentPath = pathname;

interface Props {
  prevNav?: string;
  title: string;
  description: string;
  hideNavPortrait?: boolean;
}

const { title, description, prevNav, hideNavPortrait } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={"Matthew Ubalde | " + title} description={description} />
  </head>
  <body
    class="overflow-x-hidden flex flex-col justify-between min-h-screen bg-slate-800 bg-linear-to-b from-slate-800 to-slate-950 text-cyan-50"
  >
    <Image
      src={gridBg}
      alt=""
      class="fixed -left-1 -top-1 w-[200%] opacity-10 rotate-1 pointer-events-none"
    />
    <!-- HEADER / NAV SECTION -->
    <header
      class="z-50 pointer-events-auto group sticky xl:fixed inset-x-0 top-0 flex flex-row gap-2 px-2 py-2 from-gray-950 to-transparent bg-linear-to-b"
    >
      <Image src={gridBg} alt="Portrait of Matthew Ubalde" class="bg-slate-900 size-16 rounded-xl" />
      <div class="flex flex-col justify-center w-full h-full">
        <h1><a href="/personal-portfolio-astro">Matthew Ubalde</a></h1>
        <nav class="flex flex-row gap-2 text-xl text-sky-300">
          <a href="/personal-portfolio-astro/projects">Projects</a>
          <a href="/personal-portfolio-astro/articles">Articles</a>
          <a href="/personal-portfolio-astro/career">Career</a>
        </nav>
      </div>
    </header>
    <!-- HEADER / NAV SECTION -->

    <!-- LANDING SECTION -->
    {
      Astro.slots.has("top") && (
          <slot name="top" />
      )
    }
    <!-- LANDING SECTION -->

    <!-- MAIN SECTION -->
    <main class="md:mx-auto md:w-3/4 lg:w-1/2">
      <slot />
    </main>
    <!-- MAIN SECTION -->

    <!-- FOOTER SECTION -->
    <Footer />
    <!-- FOOTER SECTION -->
  </body>
</html>
