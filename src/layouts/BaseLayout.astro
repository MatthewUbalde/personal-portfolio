---
/**
 * The base of the entire website.
 * It holds the metadata in the head, Navbars, and holds the main content.
 */
import { Image } from "astro:assets";

import Navbar from "../components/Navbar.astro";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";

import gridBg from "../assets/grid-bg.svg";

const pathname = Astro.url.pathname;

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={"Matthew Ubalde | " + title} description={description} />
  </head>
  <body
    class="overflow-x-hidden flex flex-col justify-between min-h-screen bg-slate-800 bg-linear-to-b from-slate-800 to-slate-950 text-cyan-50"
  >
    <Image
      src={gridBg}
      alt=""
      class="fixed -left-1 -top-1 w-[200%] opacity-10 rotate-1 pointer-events-none"
    />

    <!-- HEADER / NAV SECTION -->
    <Navbar />
    <!-- HEADER / NAV SECTION -->

    <!-- LANDING SECTION -->
    {Astro.slots.has("top") && <slot name="top" />}
    <!-- LANDING SECTION -->

    <!-- MAIN SECTION -->
    <main class="lg:mx-auto lg:w-3/4">
      <slot />
    </main>
    <!-- MAIN SECTION -->

    <!-- FOOTER SECTION -->
    <Footer />
    <!-- FOOTER SECTION -->
  </body>
</html>
